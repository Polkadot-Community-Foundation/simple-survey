{
  "name": "survey-dapp",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build:frontend": "tsc -b && vite build",
    "build:contracts": "cdm build",
    "deploy:contract": "cdm deploy -n w3s && npm run install:contracts",
    "install:contracts": "cdm install -n w3s @polkadot/surveys",
    "deploy:frontend": "npm run build:frontend && bulletin-deploy --env summit --mnemonic \"$MNEMONIC\" --config ./polkadot-app-deploy.config.ts ./dist survey.dot",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@novasamatech/host-api": "^0.8.4",
    "@novasamatech/host-api-wrapper": "^0.8.4",
    "@parity/product-sdk": "^0.9.0",
    "@parity/product-sdk-address": "^0.1.1",
    "@parity/product-sdk-contracts": "^0.7.0",
    "@parity/product-sdk-descriptors": "^0.6.1",
    "@parity/product-sdk-tx": "^0.2.7",
    "@polkadot-api/ws-provider": "^0.9.0",
    "multiformats": "^13.4.2",
    "polkadot-api": "^2.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "@polkadot-api/json-rpc-provider": "0.2.0"
  }
}
